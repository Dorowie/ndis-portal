{
  "openapi": "3.0.1",
  "info": {
    "title": "NDISPortal.API",
    "version": "1.0"
  },
  "paths": {
    "/api/support-workers": {
      "get": {
        "tags": [
          "SupportWorkers"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "SupportWorkers"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSupportWorkerDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSupportWorkerDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSupportWorkerDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateSupportWorkerDto": {
        "required": [
          "assignedServiceId",
          "email",
          "firstName",
          "lastName",
          "phone"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "maxLength": 20,
            "minLength": 0,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "lastName": {
            "maxLength": 30,
            "minLength": 0,
            "pattern": "^[a-zA-Z\\s]+$",
            "type": "string"
          },
          "email": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "phone": {
            "minLength": 1,
            "pattern": "^\\d{10,15}$",
            "type": "string"
          },
          "assignedServiceId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}